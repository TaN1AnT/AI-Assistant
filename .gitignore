# ═══════════════════════════════════════════════════════════
# AI-Assistant — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────
__pycache__/
*.py[codz]
*$py.class
*.so
*.egg
*.egg-info/
.installed.cfg
MANIFEST
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
pip-log.txt
pip-delete-this-directory.txt

# ── Virtual Environments ──────────────────────────────────
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.pixi/
__pypackages__/

# ── Environment / Secrets ─────────────────────────────────
.env
.env.local
.env.production
.envrc
# .env.example — НЕ ігноруємо (шаблон для розробників)

# ── Credentials / Service Accounts ────────────────────────
*.pem
*.key
service_account.json
service-account.json
accesses.txt

# ── Node.js (suppa-mcp-server) ───────────────────────────
node_modules/
suppa-mcp-server/node_modules/
suppa-mcp-server/dist/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── IDE / Editors ─────────────────────────────────────────
# JetBrains (PyCharm, WebStorm, IntelliJ)
.idea/

# Visual Studio Code
.vscode/

# Cursor
.cursor/
.cursorignore
.cursorindexingignore

# ── Testing / Coverage ────────────────────────────────────
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ── Type Checking / Linting ───────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.pytype/
.ruff_cache/
cython_debug/

# ── Documents (PDF — завантажуються в RAG corpus, не в git) ──
documents/*.pdf

# ── Docs build artifacts ─────────────────────────────────
docs/_build/
*.resolved

# ── Logs ──────────────────────────────────────────────────
*.log

# ── OS Files ──────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# ── Misc ──────────────────────────────────────────────────
*.manifest
*.spec
*.mo
*.pot
*.sage.py
celerybeat-schedule
celerybeat.pid
.pdm-python
.pdm-build/
.pypirc
/site
