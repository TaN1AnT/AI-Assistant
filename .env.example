# ── Google Cloud Config ──
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=europe-west4
VERTEX_RAG_CORPUS_ID=your-rag-corpus-id

# ── LLM Config ──
GEMINI_MODEL=gemini-2.0-flash-lite

# ── Suppa CRM ──
SUPPA_API_KEY=your-suppa-api-key
SUPPA_API_URL=https://sp.modern-expo.com

# ── n8n Webhook Authentication ──
N8N_WEBHOOK_SECRET=your-secure-webhook-secret

# ── MCP Server (Knowledge only, CRM is suppa-mcp-server via stdio) ──
MCP_KNOWLEDGE_URL=http://127.0.0.1:8081/sse
