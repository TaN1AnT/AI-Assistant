# ── Google Cloud Config ──
GOOGLE_APPLICATION_CREDENTIALS=service-account.json
GOOGLE_PROJECT_ID=your-project-id
GOOGLE_LOCATION=europe-west4
VERTEX_RAG_CORPUS_ID=your-rag-corpus-id

# ── LLM Config ──
GEMINI_MODEL=gemini-2.5-flash-lite

# ── n8n Webhook Authentication ──
# Secret shared with n8n to verify incoming requests
N8N_WEBHOOK_SECRET=your-secure-webhook-secret

# ── MCP Server Internal URLs ──
MCP_KNOWLEDGE_URL=http://127.0.0.1:8081/sse
MCP_CRM_URL=http://127.0.0.1:8082/sse
MCP_AUTOMATION_URL=http://127.0.0.1:8083/sse

# ── n8n Result-Fetching Webhooks (CRM) ──
N8N_WEBHOOK_CRM_GET_COMMENTS=https://your-n8n-instance.com/webhook/crm/comments
N8N_WEBHOOK_CRM_GET_CHECKLISTS=https://your-n8n-instance.com/webhook/crm/checklists
N8N_WEBHOOK_CRM_GET_SUBTASKS=https://your-n8n-instance.com/webhook/crm/subtasks
N8N_WEBHOOK_CRM_GET_APPROVALS=https://your-n8n-instance.com/webhook/crm/approvals
N8N_WEBHOOK_CRM_GET_TIME=https://your-n8n-instance.com/webhook/crm/time

